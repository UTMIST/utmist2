{
  "compilerOptions": {
    "target": "es5", // Updated from ESNEXT to es5
    "useDefineForClassFields": true, // Retained from the first file
    "lib": ["dom", "dom.iterable", "esnext"], // Merged libraries
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true, // Updated from false to true
    "allowSyntheticDefaultImports": true, // Retained from the first file
    "strict": true,
    "forceConsistentCasingInFileNames": true, // Retained from the first file
    "module": "esnext",
    // "moduleResolution": "bundler", // Updated from Node to bundler
    "moduleResolution": "node", // Updated from Node to bundler
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve", // Updated from react-jsx to preserve
    "incremental": true, // Added from the second file
    "plugins": [
      {
        "name": "next" // Added from the second file
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@src/*": ["./src/*"],
      "@pages/*": ["./pages/*"],
      "@app/*": ["./app/*"],
      "@root/*": ["./app/(root)/*"],
      "@ai2/*": ["./app/common/ai2/*"],
      "@ai2components/*": ["./app/common/ai2/*"],
      "@/lib/*": ["./app/common/ai2/lib/*"],
      "@assets/*": ["./public/assets/*"],
      "@schema/*": ["./app/schema/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/@types"], // Merged includes
  "exclude": ["node_modules"] // Retained from the second file
}